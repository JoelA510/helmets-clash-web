      </div>
      <div
        class="text-sm text-stone-600 mb-4"
      >
        Leading 
        Grimhold
      </div>
      <p
        class="text-xs text-stone-600 mb-5"
      >
        Hand the device to 
        Player 2
        . Other players' hands, unexplored tiles, and decks are hidden until you tap Ready.
      </p>
      <button
        class="bg-amber-700 hover:bg-amber-800 text-white font-semibold px-6 py-2 rounded shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2"
        type="button"
      >
        I'm ready
      </button>
    </div>
  </div>
</div>
