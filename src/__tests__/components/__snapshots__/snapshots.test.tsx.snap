exports[`component snapshots > HelpModal 1`] = `
<div
  class="fixed inset-0 bg-black/60 flex items-center justify-center z-50"
>
  <div
    aria-labelledby="help-title"
    aria-modal="true"
    class="bg-gradient-to-b from-amber-100 to-amber-50 border-2 border-amber-700 rounded-lg p-5 max-w-lg w-full m-4 shadow-2xl focus:outline-none"
    role="dialog"
    tabindex="-1"
  >
    <div
      class="flex items-start justify-between mb-3"
    >
      <h2
        class="text-2xl font-bold"
        id="help-title"
      >
        How to Play
      </h2>
      <button
        aria-label="Close dialog"
        class="text-stone-600 hover:text-stone-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-600 focus-visible:ring-offset-1 rounded p-1"
      >
        <svg
          aria-hidden="true"
          class="lucide lucide-x"
          fill="none"
          height="20"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="20"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6 6 18"
          />
          <path
            d="m6 6 12 12"
          />
        </svg>
      </button>
    </div>
    <div
      class="text-sm space-y-2 text-stone-800"
    >
      <p>
        <b>
          Goal:
        </b>
         Be the last faction with a city standing.
      </p>
      <p>
        <b>
          Move:
        </b>
         Click or keyboard-select a unit, then click/press Enter on a blue tile to move there.
      </p>
      <p>
        <b>
          Attack:
        </b>
         Select a red-outlined enemy in range. Melee units counter-attack.
      </p>
      <p>
        <b>
          Cards:
        </b>
         Spend Orders (refill each turn) on tactical cards.
      </p>
      <p>
        <b>
          Your City:
        </b>
         Click or press Enter on it to 
        <b>
          Recruit
        </b>
         units or 
        <b>
          Construct
        </b>
         buildings. Food comes from grassland/forest near your city; Granary doubles food output.
      </p>
      <p>
        <b>
          Buildings:
        </b>
         Each provides a permanent effect — yields, HP, card draw, orders, or vision.
      </p>
      <h3
        class="font-semibold mt-4 text-base"
      >
        Keyboard controls
      </h3>
      <ul
        class="list-disc list-inside space-y-1 text-xs"
      >
        <li>
          <kbd>
            Arrow keys
          </kbd>
           — move the hex cursor
        </li>
        <li>
          <kbd>
            Page Up
          </kbd>
           / 
          <kbd>
            Page Down
          </kbd>
           — diagonal hex moves
        </li>
        <li>
          <kbd>
            Enter
          </kbd>
           or 
          <kbd>
            Space
          </kbd>
           — select / move / attack / open city
        </li>
        <li>
          <kbd>
            Esc
          </kbd>
           — cancel selection or close dialogs
        </li>
        <li>
          <kbd>
            E
          </kbd>
           — end your turn
        </li>
        <li>
          <kbd>
            Tab
          </kbd>
           — jump between map, hand, and toolbar
        </li>
      </ul>
      <p
        class="text-xs text-stone-600 italic mt-2"
      >
        Animations respect your OS reduced-motion preference.
      </p>
    </div>
  </div>
</div>
`;

