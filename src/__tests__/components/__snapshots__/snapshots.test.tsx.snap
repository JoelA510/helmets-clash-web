exports[`component snapshots > TutorialOverlay 1`] = `
<div
  class="fixed inset-0 bg-black/60 flex items-center justify-center z-50"
>
  <div
    aria-labelledby="tutorial-title"
    aria-modal="true"
    class="bg-gradient-to-b from-amber-100 to-amber-50 border-2 border-amber-700 rounded-lg p-5 max-w-xl w-full m-4 shadow-2xl focus:outline-none"
    role="dialog"
    tabindex="-1"
  >
    <div
      class="flex items-start justify-between mb-3"
    >
      <h2
        class="text-2xl font-bold"
        id="tutorial-title"
      >
        Welcome to Helmets Clash
      </h2>
      <button
        aria-label="Close dialog"
        class="text-stone-600 hover:text-stone-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-600 focus-visible:ring-offset-1 rounded p-1"
      >
        <svg
          aria-hidden="true"
          class="lucide lucide-x"
          fill="none"
          height="20"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          width="20"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6 6 18"
          />
          <path
            d="m6 6 12 12"
          />
        </svg>
      </button>
    </div>
    <div
      class="text-sm text-stone-800 space-y-3"
    >
      <p>
        <b>
          Goal:
        </b>
         Be the last faction with a city standing.
      </p>
      <ol
        class="list-decimal list-inside space-y-1"
      >
        <li>
          Click one of your units (the bright-bordered ones) to select it.
        </li>
        <li>
          Blue hexes show where it can move; red-outlined enemies are in attack range.
        </li>
        <li>
          Click your city to 
          <b>
            Recruit
          </b>
           new units or 
          <b>
            Construct
          </b>
           buildings. Both cost gold + food.
        </li>
        <li>
          Your hand (bottom of screen) holds tactical 
          <b>
            cards
          </b>
          . Spending Orders plays them.
        </li>
        <li>
          When you're done, click 
          <b>
            End Turn
          </b>
           (or press 
          <kbd>
            E
          </kbd>
          ).
        </li>
      </ol>
      <p
        class="text-xs text-stone-600 italic"
      >
        Keyboard: arrows move a cursor, Enter acts, Esc cancels, 
        <kbd>
          ?
        </kbd>
         opens help. Theme and turn-warning settings are behind the gear icon in the toolbar.
      </p>
      <div
        class="text-right pt-2"
      >
        <button
          class="bg-amber-700 hover:bg-amber-800 text-white font-semibold px-5 py-2 rounded shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2"
          type="button"
        >
          Got it
        </button>
      </div>
    </div>
  </div>
</div>
`;
